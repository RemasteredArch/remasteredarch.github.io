        "ci": "sudo \"$(which act)\" -P 'ubuntu-24.04=catthehacker/ubuntu:act-22.04'"
    },
    "dependencies": {
        "@astrojs/check": "^0.9.4",
        "astro": "^4.16.10",
        "typescript": "^5.6.3"
    },
    "devDependencies": {
        "prettier": "^3.3.3",
        "prettier-plugin-astro": "^0.14.1"
    }
}
