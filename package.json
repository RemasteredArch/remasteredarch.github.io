{
    "name": "remasteredarch-website",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "fmt": "prettier --write .",
        "dev": "astro dev",
        "start": "astro dev",
        "sync": "astro sync",
        "check": "astro check && prettier --check .",
